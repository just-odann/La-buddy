<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <TextView
        android:id="@+id/tvInboxHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chats"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:padding="20dp"
        android:layout_alignParentTop="true"/>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etSearchInbox"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_below="@id/tvInboxHeader"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_bottom_sheet"
        android:backgroundTint="#F1F1F1"
        android:hint="Search"
        android:paddingStart="16dp"
        android:textSize="16sp"
        android:importantForAutofill="no" />

    <!-- Conversations List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvInbox"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/etSearchInbox"
        android:layout_above="@id/bottomNavigation"
        android:paddingTop="8dp"/>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:menu="@menu/admin_bottom_nav"
        app:itemIconTint="#1A73E8"
        app:itemTextColor="#1A73E8"
        app:labelVisibilityMode="labeled" />

</RelativeLayout>